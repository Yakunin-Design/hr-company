{
  "scripts": {
    "start": "node ./build/server",
    "dev": "clear; eval $(cat .env) npx nodemon ./build/server.js --config ./config/nodemon.json",
    "dev-w": "clear; eval $(cat .env) nodemon ./build/server.js --config ./config/nodemon.json",
    "ts": "npx tsc -w --project ./config/tsconfig.json",
    "ts-w": "tsc -w --project ./config/tsconfig.json"
  },
  "dependencies": {
    "express": "^4.17.3",
    "hbs": "^4.2.0",
    "jsonwebtoken": "^8.5.1",
    "mongodb": "^4.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/node": "^17.0.25",
    "nodemon": "^2.0.15",
    "typescript": "^4.6.3"
  }
}
